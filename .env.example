# ============================================================
# Configuration du RPG Bot Discord
# ============================================================
# 1. Copie ce fichier : cp .env.example .env
# 2. Remplis les valeurs ci-dessous
# 3. Ne commite JAMAIS le fichier .env dans git
# ============================================================

# Token du bot Discord
# Obtiens-le sur : https://discord.com/developers/applications
# → Ton application → Bot → Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# URLs d'export CSV des Google Sheets (fichier → Partager → Publier sur le web → CSV)
# Format : https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_CHARACTER=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_CRAFT=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_ITEMS=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_LOOTBOXES=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_POWER=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_ENEMIES=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_MEMORIES=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_NPCS=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_QUESTS=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
GSHEET_TRADES=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv
